topoChanger
{
    type    refiner;

    libs    ("libfvMeshTopoChangers.so");

    refineInterval  1;

    field           refinementField;

    lowerRefineLevel 0.1;

    upperRefineLevel 10.0;

    nBufferLayers   5;

    maxRefinement   1;

    maxCells        20000000;

    dumpLevel       true;
}

