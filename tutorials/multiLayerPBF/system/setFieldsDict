FoamFile
{
    version         2;
    format          ascii;
    class           dictionary;
    location        "system";
    object          setFieldsDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

zones
{
    powder
    {
        type box;

        box (-1 -1 -4e-5) (1 1 1);

        values
        {
            alpha.powder 1;
        }
    }
}


