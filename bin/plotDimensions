#!/usr/bin/env python3
import os
import argparse
import glob
import pandas as pd
import matplotlib.pyplot as plt

plt.rcParams.update({
    "font.family": "serif",
    "font.size": 8,
    "axes.labelsize": 8,
    "xtick.labelsize": 8,
    "ytick.labelsize": 8,
    "figure.dpi": 300,
    "mathtext.fontset": "dejavuserif"
})

def plot_meltpool(cases, output):
    fig, axes = plt.subplots(
        1, 3, figsize=(6.5, 2), constrained_layout=True, sharex=True
    )
    
    cols = ['length(m)', 'width(m)', 'depth(m)']
    y_labs = ['Length ($\mu$m)', 'Width ($\mu$m)', 'Depth ($\mu$m)']
    
    t_min, t_max = float('inf'), float('-inf')

    for case_path in cases:
        abs_path = os.path.abspath(case_path)
        case_name = os.path.basename(abs_path)
        
        data_dir = os.path.join(
            abs_path,
            "postProcessing",
            "meltPoolDimensions"
        )
        
        if not os.path.exists(data_dir):
            print(f"Warning: No melt pool data found in {case_name}")
            continue

        csv_files = sorted(glob.glob(os.path.join(data_dir, "*.csv")))
        
        for csv_file in csv_files:
            isotherm = os.path.basename(csv_file).replace('.csv', '')
            label = f"{case_name} ({isotherm}K)"
            
            df = pd.read_csv(csv_file)
            if df.empty:
                continue

            df['time(s)'] = df['time(s)'] * 1e3         
            t_min = min(t_min, df['time(s)'].min())
            t_max = max(t_max, df['time(s)'].max())
          
            for j in range(3):
                y_data = df[cols[j]] * 1e6
                axes[j].plot(df['time(s)'], y_data, label=label)

    for j in range(3):
        axes[j].set_xlabel('Time (ms)')
        axes[j].set_ylabel(y_labs[j])
        axes[j].grid(True, which="both", ls="-", alpha=0.1)
        
        axes[j].set_xlim(t_min, t_max)
        axes[j].set_ylim(bottom=0)
        
        axes[j].ticklabel_format(style='sci', axis='x', scilimits=(0,0))
        axes[j].ticklabel_format(style='plain', axis='y')

    handles, labels = axes[0].get_legend_handles_labels()
    if handles:
        fig.legend(
            handles, labels, loc='upper center', 
            bbox_to_anchor=(0.5, 1.12), ncol=2, frameon=True
        )

    plt.minorticks_on()
    plt.savefig(output, dpi=300)
    print(f"Melt pool plot (microns) saved to: {output}")

if __name__ == "__main__":
    parser = argparse.ArgumentParser(
        description='Plot melt pool dimensions in microns over time.'
    )
    parser.add_argument('cases', nargs='*', default=['.'],
                        help='Case directory/directories (default: .)')
    parser.add_argument('-o', '--output',
                        default='melt_pool_dimensions.png', 
                        help='Output image name (e.g. plot.pdf)')

    args = parser.parse_args()
    plot_meltpool(args.cases, args.output)
